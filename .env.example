# ============================================================
# .env.example — NEXORA Monorepo Environment Variables Template
# ============================================================
# Copy this file to .env locally or add these keys to Vercel dashboard.

# ── MongoDB Connection ───────────────────────────────────────
# Locally: Use local daemon mongodb://localhost:27017/nexora
# Vercel Production: Use a MongoDB Atlas URI
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/nexora?retryWrites=true&w=majority

# ── Authentication ───────────────────────────────────────────
# Random high-entropy secret string for signing JWT tokens
JWT_SECRET=your_jwt_secret_key_change_this_in_production

# ── OpenAI API Key ───────────────────────────────────────────
# For the AI Marketing and Project chat assistant
OPENAI_API_KEY=your_openai_api_key_here

# ── SMTP Email Service ───────────────────────────────────────
# For sending project notifications and proposal PDFs
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password

# ── Security & Limits ────────────────────────────────────────
# Rate limits and allowed origins (Comma separated, optional)
RATE_LIMIT_MAX=100
ALLOWED_ORIGINS=https://nexora-businesses.vercel.app,http://localhost:3000
